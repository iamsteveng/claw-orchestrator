{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "paths": {
      "@claw/shared-types": ["./packages/shared-types/src/index.ts"],
      "@claw/shared-config": ["./packages/shared-config/src/index.ts"],
      "@claw/docker-client": ["./packages/docker-client/src/index.ts"],
      "@claw/test-utils": ["./packages/test-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
