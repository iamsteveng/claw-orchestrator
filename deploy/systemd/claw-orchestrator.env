# claw-orchestrator.env
# Environment variables for all claw-orchestrator systemd services.
# Format: KEY=value (no export, no inline comments)
# Copy secrets from .env before installing.

CONTROL_PLANE_PORT=3200
SLACK_RELAY_PORT=3101
DATABASE_URL=file:/data/claw-orchestrator/db.sqlite
DATA_DIR=/data/tenants
TENANT_IMAGE=claw-tenant:latest
TEMPLATES_DIR=/home/ubuntu/.openclaw/workspace/claw-orchestrator/templates/workspace
SLACK_SIGNING_SECRET=replace-with-real-value
SLACK_BOT_TOKEN=replace-with-real-value
CONTROL_PLANE_URL=http://localhost:3200
SCHEDULER_INTERVAL_MS=60000
IDLE_STOP_HOURS=48
LOG_LEVEL=info
NODE_ENV=production
