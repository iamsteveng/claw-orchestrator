# claw-orchestrator.env
# Environment variables for all claw-orchestrator systemd services.
# Format: KEY=value (no export, no inline comments)
# Copy secrets from .env before installing.

HOME=/home/ubuntu
CONTROL_PLANE_PORT=3200
SLACK_RELAY_PORT=3101
DATABASE_URL=file:/data/claw-orchestrator/db.sqlite
DATA_DIR=/data/tenants
HOST_DATA_DIR=
DATA_MOUNT=/data
TENANT_IMAGE=claw-tenant:latest
TEMPLATES_DIR=__REPO_DIR__/templates/workspace
OPENCLAW_CONFIG_TEMPLATE=__REPO_DIR__/docker/tenant-image/openclaw.json
SLACK_SIGNING_SECRET=replace-with-real-value
SLACK_BOT_TOKEN=replace-with-real-value
CONTROL_PLANE_URL=http://localhost:3200
SCHEDULER_INTERVAL_MS=60000
IDLE_STOP_HOURS=48
LOG_LEVEL=info
NODE_ENV=production
MAX_ACTIVE_TENANTS=10
ACTIVE_TENANTS_OVERFLOW_POLICY=queue
CONTAINER_NETWORK=
S3_BUCKET=
# AWS credentials for Bedrock model access in tenant containers.
# Leave empty to skip injection (e.g. when using an IAM instance role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1
AWS_SESSION_TOKEN=
# Public HTTPS URL for the Slack relay (used by validate-deployment.sh).
# Must match the domain in /etc/caddy/Caddyfile.
RELAY_PUBLIC_URL=
