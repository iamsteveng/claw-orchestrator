# claw-backup.service — One-shot backup service triggered by claw-backup.timer

[Unit]
Description=Claw Orchestrator Daily Backup
After=network.target

[Service]
Type=oneshot
User=claw
EnvironmentFile=-/opt/claw-orchestrator/.env
ExecStart=/opt/claw-orchestrator/deploy/scripts/backup.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=claw-backup
