# Control Plane
CONTROL_PLANE_PORT=3200
DATABASE_URL=file:/data/claw-orchestrator/db.sqlite
DATA_DIR=/data/tenants
# HOST_DATA_DIR: only needed when control plane runs inside Docker.
# Set to the host-side path matching DATA_DIR so docker run volume mounts resolve correctly.
# HOST_DATA_DIR=/data/tenants
TENANT_IMAGE=claw-tenant:sha-latest
LOG_LEVEL=info
MAX_ACTIVE_TENANTS=10
# ACTIVE_TENANTS_OVERFLOW_POLICY: queue | reject
ACTIVE_TENANTS_OVERFLOW_POLICY=queue
# Path to workspace templates directory.
# Leave TEMPLATES_DIR unset for the normal deploy/scripts/install.sh + update.sh flow:
# the runtime env generator will point it at <repo checkout>/templates/workspace automatically.
# Uncomment only when you intentionally need a non-default templates path.
# TEMPLATES_DIR=/srv/claw-orchestrator/templates/workspace
# DATA_MOUNT is only needed when scheduler archive/quota paths differ from /data.
# DATA_MOUNT=/data
# CONTAINER_NETWORK is only needed when the control plane runs inside Docker Compose.
# CONTAINER_NETWORK=claw_default

# Slack Relay
# The systemd runtime env generated by install.sh / update.sh also uses 3101.
SLACK_RELAY_PORT=3101
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
CONTROL_PLANE_URL=http://localhost:3200

# Scheduler
SCHEDULER_INTERVAL_MS=60000
IDLE_STOP_HOURS=48
# Optional backup destination when daily backup timer is enabled.
# S3_BUCKET=my-claw-backups

# Model Auth — NO ANTHROPIC_API_KEY here.
# OpenClaw model auth is provided via a read-only bind-mount of the host's auth-profiles.json
# into every tenant container. The file path on the host is:
#   ~/.openclaw/agents/main/agent/auth-profiles.json
# Mounted into each container at:
#   /root/.openclaw/agents/main/agent/auth-profiles.json  (read-only)
# Token rotation on the host is picked up immediately by running containers on next read.
# If the file is missing or the token is revoked, ALL tenants lose model access simultaneously.
